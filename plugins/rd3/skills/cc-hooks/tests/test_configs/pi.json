{
    "hooks": {
        "SessionStart": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'session started'"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'pre-tool'"
                    }
                ]
            }
        ]
    }
}
