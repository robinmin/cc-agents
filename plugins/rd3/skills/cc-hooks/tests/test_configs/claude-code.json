{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ./scripts/validate-write.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ./scripts/check-tests.sh"
                    }
                ]
            }
        ]
    }
}
