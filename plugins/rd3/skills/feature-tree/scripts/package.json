{
    "name": "ftree",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "check": "biome check . && bun run typecheck && bun run test:coverage",
        "test": "bun test --coverage --coverage-reporter=lcov --coverage-dir=coverage && bun run _scripts/check-coverage.ts",
        "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage --reporter=dots && bun run _scripts/check-coverage.ts",
        "format": "biome format --write .",
        "lint-fix": "biome lint --write .",
        "typecheck": "tsc --noEmit",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "dev:cli": "bun run apps/cli/src/index.ts",
        "dev:server": "bun --hot run apps/server/src/index.ts",
        "build:cli": "bun build --compile apps/cli/src/index.ts --outfile dist/tbs",
        "tree": "tree . -a -I 'node_modules|.git|coverage'",
        "pub2npmjs": "npm whoami >/dev/null 2>&1 || { echo 'Error: not logged in to npm. Run `npm login` first.'; exit 1; } && npm publish --access public",
        "clean-demo": "bun run _scripts/clean-demo.ts"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.0.0",
        "@types/bun": "^1.3.12",
        "drizzle-kit": "^0.31.0",
        "typescript": "^5.7.0"
    }
}
