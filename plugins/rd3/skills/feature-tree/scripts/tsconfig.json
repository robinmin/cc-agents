{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "paths": {
            "@ftree/core": ["./packages/core/src/index.ts"]
        }
    },
    "include": ["packages/*/src", "apps/*/src", "_scripts"],
    "exclude": ["node_modules", "dist", "coverage", "drizzle"]
}
