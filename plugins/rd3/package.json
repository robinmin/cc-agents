{
    "name": "@cc-agents/rd3",
    "version": "0.6.4",
    "type": "module",
    "description": "Universal skill creator for multiple AI coding agents",
    "private": true,
    "scripts": {
        "dev": "bun run --watch",
        "build": "bun build",
        "check": "bun run lint && bun run typecheck && bun run test",
        "check:rd3": "bun run lint && bun run typecheck && bun run test:coverage",
        "check:ftree": "bun run lint:ftree && bun run typecheck:ftree && bun run test:ftree",
        "lint:ftree": "biome lint ./skills/feature-tree/scripts",
        "typecheck:ftree": "tsc --noEmit --project ../../tsconfig.json",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --project ../../tsconfig.json",

        "test": "bun test ./tests ./skills/*/tests --reporter=dots",
        "test:watch": "bun test ./tests ./skills/*/tests --watch",
        "test:coverage": "bun test ./tests ./skills/*/tests --coverage",
        "test:coverage:watch": "bun test ./tests ./skills/*/tests --coverage --watch",
        "test:ftree": "bun test ./skills/feature-tree/scripts/packages/core/tests --reporter=dots",

        "build:tasks-ui": "bun run --cwd ./skills/tasks/scripts/server/ui build",
        "build:tasks": "bun build ./skills/tasks/scripts/tasks.ts --target bun --outfile ./skills/tasks/scripts/dist/tasks.js",
        "build:ftree": "bun build ./skills/feature-tree/scripts/apps/cli/src/index.ts --target bun --outfile ./skills/feature-tree/scripts/dist/ftree.js",
        "build:orchestrator": "bun build ./skills/orchestration-v2/scripts/run.ts --target bun --outfile ./skills/orchestration-v2/scripts/dist/orchestrator.js",
        "build:cov": "bun build ./skills/verification-chain/scripts/cli.ts --target bun --outfile ./skills/verification-chain/scripts/dist/cov.js",

        "build-all": "bun run build:tasks && bun run build:tasks-ui && bun run build:ftree && bun run build:orchestrator && bun run build:cov",

        "add-symblink-tasks": "[ -L ~/.bun/bin/tasks ] || ln -sf ~/projects/cc-agents/plugins/rd3/skills/tasks/scripts/dist/tasks.js ~/.bun/bin/tasks",
        "add-symblink-ftree": "[ -L ~/.bun/bin/ftree ] || ln -sf ~/projects/cc-agents/plugins/rd3/skills/feature-tree/scripts/dist/ftree.js ~/.bun/bin/ftree",
        "add-symblink-orchestrator": "[ -L ~/.bun/bin/orchestrator ] || ln -sf ~/projects/cc-agents/plugins/rd3/skills/orchestration-v2/scripts/dist/orchestrator.js ~/.bun/bin/orchestrator",
        "add-symblink-cov": "[ -L ~/.bun/bin/cov ] || ln -sf ~/projects/cc-agents/plugins/rd3/skills/verification-chain/scripts/dist/cov.js ~/.bun/bin/cov",

        "symblink-all": "bun run add-symblink-tasks && bun run add-symblink-ftree && bun run add-symblink-orchestrator && bun run add-symblink-cov"
    },
    "dependencies": {
        "yaml": "2.8.3"
    }
}
