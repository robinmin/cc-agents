{
    "name": "@cc-agents/rd3",
    "version": "0.5.5",
    "type": "module",
    "description": "Universal skill creator for multiple AI coding agents",
    "private": true,
    "scripts": {
        "dev": "bun run --watch",
        "build": "bun build",
        "check": "bun run lint && bun run typecheck && bun run test",
        "check:rd3": "bun run lint && bun run typecheck && bun run test:coverage",
        "check:ftree": "bun run lint:ftree && bun run typecheck:ftree && bun run test:ftree",
        "lint:ftree": "biome lint ./skills/feature-tree/scripts",
        "typecheck:ftree": "tsc --noEmit --project ../../tsconfig.json",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --project ../../tsconfig.json",
        "test": "bun test ./tests ./skills/*/tests --reporter=dots",
        "test:watch": "bun test ./tests ./skills/*/tests --watch",
        "test:coverage": "bun test ./tests ./skills/*/tests --coverage",
        "test:coverage:watch": "bun test ./tests ./skills/*/tests --coverage --watch",
        "test:ftree": "bun test ./skills/feature-tree/scripts/packages/core/tests --reporter=dots",
        "build:tasks": "bun build ./skills/tasks/scripts/tasks.ts --target bun --outfile ./skills/tasks/scripts/dist/tasks.js",
        "tasks": "bun ./skills/tasks/scripts/tasks.ts",
        "ftree": "bun ./skills/feature-tree/scripts/apps/cli/src/index.ts"
    },
    "dependencies": {
        "yaml": "2.8.3"
    }
}
