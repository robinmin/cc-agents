{
    "name": "@cc-agents/rd3",
    "version": "0.3.2",
    "type": "module",
    "description": "Universal skill creator for multiple AI coding agents",
    "private": true,
    "scripts": {
        "dev": "bun run --watch",
        "build": "bun build",
        "check": "bun run lint && bun run typecheck && bun run test",
        "check:rd3": "bun run lint && bun run typecheck && bun run test:coverage",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --project ../../tsconfig.json",
        "test": "bun test ./tests ./skills/*/tests --reporter=dots",
        "test:watch": "bun test ./tests ./skills/*/tests --watch",
        "test:coverage": "bun test ./tests ./skills/*/tests --coverage",
        "test:coverage:watch": "bun test ./tests ./skills/*/tests --coverage --watch",
        "tasks": "bun ./skills/tasks/scripts/tasks.ts"
    },
    "dependencies": {
        "yaml": "^2.6.1"
    }
}
