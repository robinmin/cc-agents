{
    "name": "@cc-agents/monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "CC-Agents monorepo - Bun/TypeScript/Biome unified config",
    "workspaces": [
        "plugins/rd3",
        "plugins/wt"
    ],
    "scripts": {
        "dev": "bun run --watch",
        "build": "bun run -r build",
        "lint": "biome lint plugins/rd3",
        "lint:fix": "biome lint --write plugins/rd3",
        "format": "biome format --write plugins/rd3",
        "lint:all": "biome lint plugins/rd3",
        "lint:fix:all": "biome lint --write plugins/rd3",
        "check": "bun run lint && bun run typecheck && bun run test",
        "typecheck": "tsc --noEmit",
        "test": "bun test --reporter=dots",
        "lint:rd3": "bun run --cwd plugins/rd3 lint",
        "format:rd3": "bun run --cwd plugins/rd3 format",
        "check:rd3": "bun run --cwd plugins/rd3 check",
        "typecheck:rd3": "bun run --cwd plugins/rd3 typecheck",
        "test:rd3": "bun run --cwd plugins/rd3 test --reporter=dots",
        "test:coverage:rd3": "bun run --cwd plugins/rd3 test:coverage",
        "update-cc": "claude plugin marketplace update cc-agents && claude plugin update rd3@cc-agents",
        "tasks": "bun run --cwd plugins/rd3 tasks",
        "tasks:check": "bun run --cwd plugins/rd3 check",
        "tasks:test": "bun run --cwd plugins/rd3 test"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "@types/bun": "1.3.11",
        "typescript": "^5.7.3"
    },
    "dependencies": {
        "yaml": "^2.6.1",
        "marked": "^17.0.1"
    }
}
